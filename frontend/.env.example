# API URL for the backend server
# In development with Vite proxy, this can be left as the default (/api/v1)
# In production, set to the full API URL, e.g.:
#   VITE_API_URL=https://api.example.com/api/v1
#   VITE_API_URL=/api/v1                    (same domain, path-based)
#
# Default: /api/v1
# VITE_API_URL=/api/v1
